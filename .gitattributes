# Unraid runs on Linux; CRLF breaks shell scripts (/bin/bash^M) and .page/.php.
# Force LF for every file that lands on the server.
* text=auto eol=lf
*.plg   text eol=lf
*.php   text eol=lf
*.page  text eol=lf
*.js    text eol=lf
*.css   text eol=lf
*.cfg   text eol=lf
*.sh    text eol=lf
*.md    text eol=lf
*.png   binary
